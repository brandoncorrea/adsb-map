{:paths ["src/clj" "src/cljc" "src/cljs" "resources"]

 :deps
 {org.clojure/clojure            {:mvn/version "1.12.1"}
  ch.qos.logback/logback-classic {:mvn/version "1.5.18"}
  cheshire/cheshire              {:mvn/version "5.13.0"}
  ;; 2.9.0-beta1: 2.8.x never fires :on-close (and never fails send!)
  ;; for plain HTTP streaming — closeKey notifies the accept-time
  ;; AsyncChannel, not the per-request one (#375 regression, fixed by
  ;; #578) — so SSE clients would leak forever. Verified by
  ;; adsb.stream.broadcast-test/disconnect-cleanup, which fails on 2.8.x.
  http-kit/http-kit              {:mvn/version "2.9.0-beta1"}
  metosin/malli                  {:mvn/version "0.17.0"}
  metosin/reitit                 {:mvn/version "0.7.2"}
  org.clojure/tools.logging      {:mvn/version "1.3.0"}}

 :aliases
 {;; bb dev — the backend half. Boots the real http server on :8280.
  :dev   {:main-opts ["-m" "adsb.http.server"]}

  ;; bb test:clj — clojure.test over test/clj and test/cljc.
  :test  {:extra-paths ["test/clj" "test/cljc" "test/cljs"]
          :extra-deps  {io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
          :exec-fn     cognitect.test-runner.api/test
          :exec-args   {:dirs ["test/clj" "test/cljc"]}}

  ;; bb lint — clj-kondo as a library, so nobody needs the binary installed.
  :lint  {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.09.27"}}
          :main-opts    ["-m" "clj-kondo.main"]}

  ;; bb build — tools.build packages the deployable uberjar (build.clj).
  ;; clojure -T:build uber. Runs after `shadow-cljs release app`.
  :build {:deps       {io.github.clojure/tools.build {:mvn/version "0.10.5"}}
          :ns-default build}

  :nrepl {:extra-paths ["test/clj" "test/cljc"]
          :extra-deps  {nrepl/nrepl {:mvn/version "1.3.1"}}
          :main-opts   ["-m" "nrepl.cmdline" "--port" "7888"]}}}
