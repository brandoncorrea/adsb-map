{:tasks
 {:requires ([babashka.fs :as fs]
             [babashka.process :as p])

  -npm-install
  {:doc  "Install node dependencies when node_modules is missing."
   :task (when-not (fs/exists? "node_modules")
           (shell "npm install --no-audit --no-fund"))}

  -playwright-browser
  {:doc     "Ensure the headless Chromium that Playwright drives is installed.
             Idempotent — a no-op once the browser is cached."
   :depends [-npm-install]
   :task    (shell "npx playwright install chromium")}

  css
  {:doc  "Compile the Garden stylesheet to resources/public/app.css.
          That file is BUILD OUTPUT — generated, gitignored, never edited by
          hand. src/css/adsb/css/*.clj is the source of truth; start at
          adsb.css.app, which is the cascade."
   :task (shell "clojure -M:css")}

  css:watch
  {:doc  "Recompile the stylesheet on every save under src/css. Writes once on
          start, so this alone is enough to get a styled page. The browser
          does not live-reload CSS — refresh to see the change."
   :task (shell "clojure -M:css --watch")}

  dev
  {:doc     "Backend on :8280 + shadow-cljs watch + Garden watch + nREPL,
             together.
             Config comes from the environment, backfilled from .env by
             adsb.env — bb does nothing special for it, EXCEPT ADSB_DEV_CSP.

             ADSB_DEV_CSP=true is set here, and only here. The backend serves
             a strict Content-Security-Policy (adsb.http.security), and the
             `shadow-cljs watch` build it is serving ships a dev HUD whose
             overlay sets style ATTRIBUTES — which that policy refuses. The
             flag adds one directive (style-src-attr) to unblock the HUD and
             changes nothing else. The shipped release build has no devtools
             at all, so production runs strict — see
             adsb.http.security/dev-content-security-policy."
   :depends [-npm-install]
   :task    (run! p/check
              (doall
                (for [[cmd env] [["npx shadow-cljs watch app" nil]
                                 ["clojure -M:css --watch" nil]
                                 ["clojure -M:dev" {"ADSB_DEV_CSP" "true"}]
                                 ["clojure -M:nrepl" nil]]]
                  (p/process (cond-> {:inherit  true
                                      :shutdown p/destroy-tree}
                               env (assoc :extra-env env))
                             cmd))))}

  dev-
  {:doc     "shadow-cljs watch + Garden watch + nREPL, together.
             Config comes from the environment, backfilled from .env by
             adsb.env — bb does nothing special for it."
   :depends [-npm-install]
   :task    (run! p/check
              (doall
                (for [cmd ["npx shadow-cljs watch app"
                           "clojure -M:css --watch"
                           "clojure -M:nrepl"]]
                  (p/process {:inherit true :shutdown p/destroy-tree} cmd))))}

  db:fetch
  {:doc     "Download the tar1090-db aircraft.csv.gz and shard it into
             resources/public/db/ for browser-side enrichment (adsb.enrich).
             DATA, not code: gitignored, never committed, third-party and
             large. The app degrades to absent when the directory is missing,
             so this is optional — run it to see type/registration/operator.
             See README 'Aircraft enrichment data'."
   :task    (do (load-file "script/aircraft_db.clj")
                ((resolve 'aircraft-db/build!) {}))}

  test:clj
  {:doc  "JVM suite — clojure.test over test/clj and test/cljc."
   :task (shell "clojure -X:test")}

  test:cljs
  {:doc     "Browser suite — compile the :test build, then run it in real
             headless Chromium via Playwright. Exits non-zero on any failure."
   :depends [-npm-install -playwright-browser]
   :task    (do (shell "npx shadow-cljs compile test")
                (shell "node script/run-browser-tests.mjs"))}

  test:watch
  {:doc     "shadow-cljs watch on the test build; rerun on save at :8290."
   :depends [-npm-install]
   :task    (shell "npx shadow-cljs watch test")}

  test
  {:doc     "Everything — clj, cljc, cljs. What CI runs."
   :depends [test:clj test:cljs]
   :task    (println "All test tasks passed.")}

  lint
  {:doc  "clj-kondo over src and test. Warnings are failures."
   :task (shell "clojure -M:lint --lint src test")}

  build
  {:doc     "Deployable artifact: Garden stylesheet + optimized CLJS release +
             uberjar. Deletes stale compiled js first so only the release
             bundle ships, then packages target/adsb.jar (build.clj). Echoes
             the artifact path.

             The stylesheet is compiled BEFORE the uberjar because build.clj
             copies resources/ into the jar — app.css has to exist by then.
             Garden itself stays out of the jar: it is an :css alias dep, not
             a :paths dep, so the artifact ships the compiled CSS and nothing
             that could compile it."
   :depends [-npm-install css]
   :task    (do (fs/delete-tree "resources/public/js")
                (shell "npx shadow-cljs release app")
                (shell "clojure -T:build uber")
                (println "Artifact: target/adsb.jar"))}}}
